# ─── Copy to .env.docker and adjust (production / staging) ───────────────
#   cp docker/.env.docker.example docker/.env.docker
# Mọi service trong docker-compose.yml đọc cùng file này (trừ redis/mailhog mặc định).

# ─── PostgreSQL (service: postgres) ─────────────────────────────────────
POSTGRES_USER=threads
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=threads

# ─── MinIO (service: minio) ─────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_secret

# ─── API / Express (service: api) ───────────────────────────────────────
# DATABASE_URL phải khớp POSTGRES_* và host `postgres` (tên service Docker).
NODE_ENV=production
DATABASE_URL=postgresql://threads:change_me_strong_password@postgres:5432/threads?schema=public
REDIS_URL=redis://redis:6379
SERVER_PORT=4000
SERVER_HOST=0.0.0.0
# URL public mà browser gọi tới (đổi theo domain production)
SERVER_URL=https://api.example.com
WEB_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com
# Sinh chuỗi ngẫu nhiên đủ dài (BetterAuth)
BETTER_AUTH_SECRET=replace_with_a_long_random_secret_min_32_chars
BETTER_AUTH_URL=https://app.example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
# Trùng credential MinIO nếu dùng bucket dev
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_BUCKET=threads-media
#
# SMTP — chọn một trong hai:
#
# A) Mailhog (dev trong Docker, xem mail tại http://localhost:8025)
#    SMTP_HOST=mailhog
#    SMTP_PORT=1025
#    SMTP_USER=        (để trống)
#    SMTP_PASS=        (để trống)
#
# B) Hộp thư của bạn (Gmail, v.v.) — cần mật khẩu ứng dụng / SMTP password từ nhà cung cấp
#    Gmail: smtp.gmail.com:587, SMTP_USER=email đầy đủ, SMTP_PASS=Mật khẩu ứng dụng
#    (Google Tài khoản → Bảo mật → Xác minh 2 bước → Mật khẩu ứng dụng — KHÔNG dùng mật khẩu đăng nhập thường)
#    SMTP_FROM nên trùng hoặc là alias được phép gửi từ SMTP_USER
#
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
LOG_LEVEL=info

# Better Auth: bật true nếu môi trường Docker/local vẫn gặp 429 do mọi request cùng IP phía API
# AUTH_RATE_LIMIT_DISABLED=true

# ─── Web / Next.js (service: web) ───────────────────────────────────────
# NEXT_PUBLIC_* được Next.js **nhúng lúc docker build** (xem docker/Dockerfile + compose build.args).
# Giá trị là URL mà **trình duyệt** gọi tới (không dùng hostname nội bộ `api`).
# Sau khi đổi: build lại image (`docker compose build` / `pnpm docker:rebuild`).
UPSTREAM_API_URL=http://api:4000
#
# --- Local Docker Desktop (mở http://localhost:3000 trên máy host) ---
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
#
# --- Production — comment 2 dòng trên, bỏ comment 2 dòng dưới ---
# NEXT_PUBLIC_API_URL=https://app.example.com/api
# NEXT_PUBLIC_SOCKET_URL=https://api.example.com
#
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_DEMO_USER_ID=seed_demo_user_001

# ─── docker-compose.dev.yml (hot reload, một container chạy web + api) ─
# Dùng chung file .env.docker. Compose tự set NODE_ENV=development và
# UPSTREAM_API_URL=http://127.0.0.1:4000. Chạy: pnpm docker:dev
# Dừng stack prod trước nếu trùng cổng 3000/4000/5432/6379/9000.
