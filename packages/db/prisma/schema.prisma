// Costy DB schema (Prisma ORM 7+)
//
// Connection URLs live in `prisma.config.ts` (CLI / Migrate). Runtime uses the
// `pg` driver via `@prisma/adapter-pg` — see `src/index.ts`.
//
// Enable pgvector on the database with `CREATE EXTENSION IF NOT EXISTS vector;`
// (e.g. first migration). `PostEmbedding.embedding` maps to `vector(1536)`.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ───────────────────────────── RBAC & Admin ─────────────────────────────

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  LOCKED
  BANNED
}

enum PermissionEffect {
  GRANT
  REVOKE
}

model Permission {
  id     String @id @default(cuid())
  key    String @unique
  domain String
  label  String

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  role         Role
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([role, permissionId])
  @@map("role_permissions")
}


model UserPermission {
  userId       String
  permissionId String
  effect       PermissionEffect
  grantedById  String
  createdAt    DateTime         @default(now())

  user       User       @relation("UserPermissionTarget", fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy  User       @relation("UserPermissionGrantedBy", fields: [grantedById], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
}

enum ReportTargetType {
  POST
  USER
  COMMENT
}

enum ReportReason {
  SPAM
  HARASSMENT
  NUDITY
  VIOLENCE
  HATE_SPEECH
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED
  ACTION_TAKEN
}

model Report {
  id             String           @id @default(cuid())
  reporterId     String
  targetType     ReportTargetType
  targetId       String
  reason         ReportReason
  description    String?
  status         ReportStatus     @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime         @default(now())

  reporter User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId, status])
  @@map("reports")
}

enum HashtagStatus {
  ACTIVE
  HIDDEN
  BLOCKED
}

model Hashtag {
  id        String        @id @default(cuid())
  tag       String        @unique
  status    HashtagStatus @default(ACTIVE)
  featured  Boolean       @default(false)
  createdAt DateTime      @default(now())

  posts PostHashtag[]

  @@map("hashtags")
}

model PostHashtag {
  postId    String
  hashtagId String

  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
  @@index([hashtagId])
  @@map("post_hashtags")
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("admin_audit_logs")
}

// ───────────────────────────── Users ─────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  /// Better Auth expects boolean; do not use DateTime here.
  emailVerified Boolean   @default(false)
  phone         String?   @unique
  phoneVerified DateTime?
  username      String    @unique
  /// Bcrypt hash for password login; null if user only uses OAuth/other providers.
  passwordHash  String?
  name          String?
  bio           String?
  image         String?

  role          Role       @default(USER)
  status        UserStatus @default(ACTIVE)
  bannedUntil   DateTime?
  statusReason  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  posts         Post[]         @relation("PostAuthor")
  likes         PostLike[]
  mediaUploads  Media[]        @relation("MediaOwner")
  notifications Notification[] @relation("NotificationRecipient")
  notifyActions Notification[] @relation("NotificationActor")
  followers     Follow[]       @relation("UserFollowers")
  following     Follow[]       @relation("UserFollowing")

  displayUsername String?
  sessions        Session[]
  accounts        Account[]

  chatMessagesSent       ChatMessage[]            @relation("ChatMessageSender")
  chatRoomsCreated       ChatRoom[]               @relation("ChatRoomCreator")
  chatRoomMemberships    ChatRoomMember[]
  userPublicKey          UserPublicKey?
  messageReactions       MessageReaction[]

  reportsSubmitted       Report[]         @relation("ReportReporter")
  reportsReviewed        Report[]         @relation("ReportReviewer")
  userPermissions        UserPermission[] @relation("UserPermissionTarget")
  permissionsGranted     UserPermission[] @relation("UserPermissionGrantedBy")
  adminAuditLogs         AdminAuditLog[]  @relation("AdminAuditActor")

  @@index([deletedAt])
  @@index([role])
  @@index([status])
  @@map("users")
}

// ───────────────────────────── E2EE Chat (Unified) ─────────────────

enum RoomType {
  DIRECT
  GROUP
}

model ChatRoom {
  id          String   @id @default(cuid())
  type        RoomType
  name        String?  // Null cho DIRECT, có thể null cho GROUP nếu tự generate
  createdById String?
  createdAt   DateTime @default(now())

  createdBy User?             @relation("ChatRoomCreator", fields: [createdById], references: [id], onDelete: SetNull)
  members   ChatRoomMember[]
  messages  ChatMessage[]

  // Khóa đối xứng mã hóa Room (nếu dùng chung cho cả group)
  // Trong thực tế E2EE group có thể dùng Sender Keys (Signal)
  // Ở đây lưu trữ tạm nếu dùng chung 1 khóa AES cho phòng
  // encryptedRoomKey String? 

  @@index([createdById])
  @@map("e2ee_chat_rooms")
}

model ChatRoomMember {
  roomId     String
  userId     String
  role       String    @default("MEMBER") // ADMIN, MEMBER
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  lastDeliveredAt DateTime?

  // Khóa AES của Room được mã hóa bằng Public Key của User này
  encryptedRoomKey String? @db.Text

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId])
  @@map("e2ee_chat_room_members")
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  senderId  String
  
  // Loại tin nhắn: text, image, video, file, sticker, emoji
  type      String   @default("text")

  // Chứa nội dung text, thông tin sticker, hoặc khóa giải mã Media
  // Đã được mã hóa bằng khóa AES của Room
  encryptedPayload String @db.Text

  mediaId   String?  // Foreign key đến bảng Media (cho phép server biết để tự động dọn dẹp)
  replyToId String?  // ID của tin nhắn đang reply
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room    ChatRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender  User         @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  media   Media?       @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  replyTo ChatMessage? @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies ChatMessage[] @relation("MessageReplies")
  
  isUnsent   Boolean  @default(false)
  deletedFor String[] @default([]) // Mảng các userId đã xoá tin nhắn này ở local
  reactions  MessageReaction[] @relation("MessageReactions")

  @@index([roomId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("e2ee_chat_messages")
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message ChatMessage @relation("MessageReactions", fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("message_reactions")
}

// User Public Keys cho E2EE
model UserPublicKey {
  userId    String   @id
  publicKey String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_public_keys")
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

// ───────────────────────────── Posts ─────────────────────────────

model Post {
  id       String  @id @default(cuid())
  authorId String
  content  String
  parentId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  hiddenAt  DateTime?

  author    User           @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parent    Post?          @relation("PostReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   Post[]         @relation("PostReplies")
  likes     PostLike[]
  media     Media[]
  embedding PostEmbedding?
  hashtags  PostHashtag[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([parentId])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([hiddenAt])
  @@map("posts")
}

model PostLike {
  userId    String
  postId    String
  type      String   @default("like")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@map("post_likes")
}

// pgvector-backed embeddings for semantic search. 1536 = OpenAI ada / 3-small dim.
// Adjust dimension in Phase 8 (search) when the actual model is picked.

model PostEmbedding {
  postId    String                      @id
  embedding Unsupported("vector(1536)")
  createdAt DateTime                    @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("post_embeddings")
}

// ───────────────────────────── Media ─────────────────────────────

enum MediaStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum MediaKind {
  IMAGE
  VIDEO
  AVATAR
}

model Media {
  id          String      @id @default(cuid())
  ownerId     String
  postId      String?
  kind        MediaKind
  status      MediaStatus @default(PENDING)
  mimeType    String
  sizeBytes   Int
  storagePath String      // Đường dẫn file lưu trên ổ đĩa VPS cục bộ
  publicUrl   String?     // URL tĩnh để serve (chỉ khả dụng sau khi giải mã hoặc public resource)
  width       Int?
  height      Int?
  durationMs  Int?

  expiresAt   DateTime?   // Phục vụ xóa file tự động sau 7 ngày

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User  @relation("MediaOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  post  Post? @relation(fields: [postId], references: [id], onDelete: SetNull)
  messages ChatMessage[] // Cho phép tin nhắn liên kết tới Media

  @@index([ownerId])
  @@index([postId])
  @@index([status])
  @@index([expiresAt])
  @@map("media")
}

// ───────────────────────────── Notifications ─────────────────────

enum NotificationType {
  POST_LIKED
  POST_REPLIED
  POST_COMMENTED_FOLLOWED
  USER_FOLLOWED
  MENTION
  SYSTEM
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String?
  type        NotificationType
  entityType  String?
  entityId    String?
  readAt      DateTime?

  createdAt DateTime @default(now())

  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, createdAt(sort: Desc)])
  @@index([recipientId, readAt])
  @@map("notifications")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@index([updatedAt])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
