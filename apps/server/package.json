  "devDependencies": {
    "@threads/eslint-config": "workspace:*",
    "@threads/typescript-config": "workspace:*",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/sanitize-html": "^2.13.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "eslint": "^9.15.0",
    "pino-pretty": "^11.3.0",
