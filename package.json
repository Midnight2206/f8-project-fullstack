{
  "name": "threads-clone",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready Threads-like social media app (Next.js + Express + Prisma + pgvector + Redis + BullMQ).",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @threads/db generate",
    "db:migrate": "pnpm --filter @threads/db migrate:dev",
    "db:studio": "pnpm --filter @threads/db studio",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:build": "docker build -f docker/Dockerfile -t threads-clone ."
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
