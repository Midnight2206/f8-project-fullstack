# ─────────────────────────── App ───────────────────────────
NODE_ENV=development
APP_NAME=threads-clone

# Server (Express)
SERVER_PORT=4000
SERVER_HOST=0.0.0.0
SERVER_URL=http://localhost:4000

# Web (Next.js)
WEB_PORT=3000
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
# Must match seeded demo user (`pnpm db:seed`) until BetterAuth ships
NEXT_PUBLIC_DEMO_USER_ID=seed_demo_user_001

# ─────────────────────────── Database ───────────────────────
DATABASE_URL=postgresql://threads:threads@localhost:5432/threads?schema=public

# ─────────────────────────── Redis ──────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ─────────────────────────── Auth (BetterAuth) ──────────────
BETTER_AUTH_SECRET=replace_with_64_char_random_string
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Phone/OTP (SMS provider TBD in Phase 2)
SMS_PROVIDER=stub
SMS_API_KEY=

# ─────────────────────────── Storage ────────────────────────
# MinIO (dev / staging temp storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=threads-media

# Cloudflare R2 (production permanent storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ─────────────────────────── Email ──────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@threads.local

# ─────────────────────────── Notifications (Novu) ───────────
NOVU_API_KEY=
NOVU_APP_ID=

# ─────────────────────────── Misc ───────────────────────────
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_POINTS=100
RATE_LIMIT_DURATION=60
