# ─────────────────────────── App ───────────────────────────
NODE_ENV=development
APP_NAME=threads-clone

# Server (Express)
SERVER_PORT=4000
SERVER_HOST=0.0.0.0
SERVER_URL=http://localhost:4000

# Web (Next.js)
WEB_PORT=3000
WEB_URL=http://localhost:3000
# Express cho route proxy `/api/auth` + `/api/v1` và cho `getServerSession` (mặc định http://localhost:4000).
UPSTREAM_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
# Must match seeded demo user (`pnpm db:seed`) until BetterAuth ships
NEXT_PUBLIC_DEMO_USER_ID=seed_demo_user_001

# ─────────────────────────── Database ───────────────────────
DATABASE_URL=postgresql://threads:threads@localhost:5432/threads?schema=public

# ─────────────────────────── Redis ──────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ─────────────────────────── Auth (BetterAuth) ──────────────
BETTER_AUTH_SECRET=replace_with_64_char_random_string
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (đăng nhập / đăng ký Gmail). Redirect URI trong Google Console:
# http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Client ID công khai (hiện nút Google trên UI). Đặt cùng giá trị với GOOGLE_CLIENT_ID (Web application).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Phone/OTP (SMS provider TBD in Phase 2)
SMS_PROVIDER=stub
SMS_API_KEY=

# ─────────────────────────── Storage ────────────────────────
# MinIO (dev / staging temp storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=threads-media

# ─────────────────────────── Cloudinary (signed client upload) ─
# Cloud name = Product environment settings (vd. dgj1kdgpd), KHÔNG phải tên cột "Key Name"
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────────── Email ──────────────────────────
# Gửi mail (Better Auth đặt lại mật khẩu). Local + Mailhog: HOST=localhost PORT=1025, để trống USER/PASS.
# Gmail: smtp.gmail.com:587 + SMTP_USER + Mật khẩu ứng dụng trong SMTP_PASS (không phải mật khẩu web).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@threads.local

# ─────────────────────────── Notifications (Novu) ───────────
NOVU_API_KEY=
NOVU_APP_ID=

# ─────────────────────────── Search (Vercel AI Gateway embeddings) ─
# Key tạo tại Vercel Dashboard → AI Gateway (prefix vck_)
AI_GATEWAY_API_KEY=

# ─────────────────────────── Misc ───────────────────────────
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_POINTS=500
RATE_LIMIT_DURATION=60
# Đặt true trên Docker local nếu vẫn gặp 429 (Better Auth rate limit).
AUTH_RATE_LIMIT_DISABLED=false
